# ==============================================================================
# Aparsoft AI Chatbot — Environment Variables Template
# ==============================================================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your actual API keys and secrets
# 3. Never commit .env or .env.local to Git!
#
# Docker Infrastructure:
#   PostgreSQL (pgvector17) : localhost:5433
#   Redis 7                 : localhost:6380
#
# Three databases are created automatically by docker/init-db.sh:
#   chatbot_db         → Django models (users, sessions, preferences, etc.)
#   langchain_pgvector → pgvector embeddings for RAG
#   langchain_history  → LangGraph checkpoints (conversation history)
# ==============================================================================

# ---------------------------------------------------------------------------
# Django
# ---------------------------------------------------------------------------
DEBUG=1
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_SECRET_KEY=generate-with-openssl-rand-base64-32
DJANGO_ADMIN_URL=chatbot-admin/
MASTER_ENCRYPTION_KEY=generate-with-openssl-rand-base64-32

# ---------------------------------------------------------------------------
# PostgreSQL (Docker: pgvector/pgvector:pg17)
# ---------------------------------------------------------------------------
DB_NAME=chatbot_db
DB_USER=chatbot_user
DB_PASSWORD=chatbot_pass
DB_HOST=localhost
DB_PORT=5433
DATABASE_URL=postgresql://chatbot_user:chatbot_pass@localhost:5433/chatbot_db

# ---------------------------------------------------------------------------
# pgvector — RAG embeddings (separate database)
# ---------------------------------------------------------------------------
PGVECTOR_CONNECTION_STRING=postgresql+psycopg://chatbot_user:chatbot_pass@localhost:5433/langchain_pgvector

# ---------------------------------------------------------------------------
# LangGraph Checkpointer — conversation history (separate database)
# ---------------------------------------------------------------------------
PG_CHECKPOINT_URI=postgresql://chatbot_user:chatbot_pass@localhost:5433/langchain_history?sslmode=disable

# ---------------------------------------------------------------------------
# Redis (Docker: redis:7-alpine)
# ---------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_URL=redis://localhost:6380/0

# ---------------------------------------------------------------------------
# Celery
# ---------------------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6380/1
CELERY_RESULT_BACKEND=redis://localhost:6380/2
CELERY_CONCURRENCY=3
CELERY_MAX_TASKS=200
CELERYD_PREFETCH_MULTIPLIER=1

# ---------------------------------------------------------------------------
# Pagination
# ---------------------------------------------------------------------------
DJANGO_PAGINATION_LIMIT=18

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://frontend:3000

# ---------------------------------------------------------------------------
# API Keys
# ---------------------------------------------------------------------------
OPENAI_API_KEY=your-openai-api-key-here
TAVILY_API_KEY=
ANTHROPIC_API_KEY=
HUGGINGFACEHUB_API_TOKEN=
DEEPGRAM_API_KEY=
USER_AGENT=APARSOFT_AI_Chatbot_Tutorial_1.0

# ---------------------------------------------------------------------------
# NextAuth v5
# ---------------------------------------------------------------------------
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true
NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Google OAuth
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ---------------------------------------------------------------------------
# Frontend
# ---------------------------------------------------------------------------
NEXT_PUBLIC_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_ENCRYPTION_KEY=generate-frontend-encryption-key
NEXT_PUBLIC_API_TIMEOUT=30000
NEXT_PUBLIC_API_VERSION=v1
NEXT_PUBLIC_WS_HOST=localhost:8000
NEXT_PUBLIC_WEBSOCKET_DEBUG=true
